	case 2:
		//star
		draw_self();
		//draw itemeeee
		draw_sprite(item_revealing.sprite, 0, x - 1, y - (sprite_get_height(sprite_index)/2));
	break;
	case 3:
		//star
		draw_self();
		
		//draw item
		draw_sprite(item_revealing.sprite, 0, x - 1, y - (sprite_get_height(sprite_index)/2));
	break;
	case 4:
		
