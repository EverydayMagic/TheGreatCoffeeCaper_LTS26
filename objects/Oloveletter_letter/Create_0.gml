anim_curve  = animcurve_get_channel(loveletter_animcurve, "curve1");
percent = 0;

position = 0;

starty = (144 + (sprite_get_height(sprite_index))) * 2;
endy = 144;
dist = endy - starty;

alph = 0;

visible = false;

x = 160;

letters = "Dearest secret admirer,\n\nI can feel you watching me from afar...\nFrom behind the trees while I go about my day, through the window while I eat my breakfast, your constant presence is like an angel bringing comfort to my anxious heart!\nOthers may have found your persistence unsettling or even strange.\nBut I know that the rapid beating in my chest is not fear.\nIt is LOVE!\n\nCome out from the shadows and into the light, my dear, so I may see all of you and not just your beady eyes staring unblinking into my soul.\n\nYours Always,\nStump";



